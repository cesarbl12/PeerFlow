/* PeerFlow — Dark Academic PWA Styles */
:root {
  --bg-base: #0a0f1e;
  --bg-surface: #111827;
  --bg-card: #1a2236;
  --bg-hover: #1f2d45;
  --border: #2a3a55;
  --border-light: #374b6a;
  --text-primary: #e8edf5;
  --text-secondary: #a8bdd4;
  --text-muted: #6b87a8;
  --accent: #3b82f6;
  --accent-glow: rgba(59,130,246,0.15);
  --accent-hover: #2563eb;
  --success: #10b981;
  --success-bg: rgba(16,185,129,0.1);
  --warning: #f59e0b;
  --warning-bg: rgba(245,158,11,0.1);
  --danger: #ef4444;
  --danger-bg: rgba(239,68,68,0.1);
  --purple: #8b5cf6;
  --purple-bg: rgba(139,92,246,0.1);
  --teal: #14b8a6;
  --teal-bg: rgba(20,184,166,0.1);
  --font-display: 'Syne', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --radius: 10px;
  --radius-lg: 16px;
  --shadow: 0 4px 24px rgba(0,0,0,0.4);
  --shadow-card: 0 2px 12px rgba(0,0,0,0.3);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: var(--font-mono);
  background: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

#app { position: relative; z-index: 1; }

/* ══════════════════════════════════════════
   LOGIN SCREEN
══════════════════════════════════════════ */
.login-screen {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
}
.login-container {
  width: 100%;
  max-width: 500px;
}
.login-logo {
  text-align: center;
  margin-bottom: 48px;
}
.logo-mark-lg {
  display: block;
  font-size: 52px;
  color: var(--accent);
  filter: drop-shadow(0 0 24px var(--accent));
  margin-bottom: 14px;
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { filter: drop-shadow(0 0 16px var(--accent)); }
  50% { filter: drop-shadow(0 0 32px var(--accent)); }
}
.logo-text-lg {
  display: block;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 36px;
  letter-spacing: -1px;
  background: linear-gradient(135deg, #e8edf5, #3b82f6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8px;
}
.tagline {
  display: block;
  color: var(--text-muted);
  font-size: 13px;
}
.role-cards {
  display: grid;
  gap: 14px;
}
.role-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 22px 24px;
  cursor: pointer;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  gap: 18px;
  text-align: left;
}
.role-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}
.role-card.editor:hover  { border-color: var(--accent);  box-shadow: 0 8px 32px rgba(59,130,246,0.2); }
.role-card.author:hover  { border-color: var(--teal);    box-shadow: 0 8px 32px rgba(20,184,166,0.2); }
.role-card.reviewer:hover{ border-color: var(--purple);  box-shadow: 0 8px 32px rgba(139,92,246,0.2); }
.role-icon {
  width: 54px;
  height: 54px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
}
.role-card.editor   .role-icon { background: var(--accent-glow); }
.role-card.author   .role-icon { background: var(--teal-bg); }
.role-card.reviewer .role-icon { background: var(--purple-bg); }
.role-info h3 {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 3px;
}
.role-card.editor   .role-info h3 { color: var(--accent); }
.role-card.author   .role-info h3 { color: var(--teal); }
.role-card.reviewer .role-info h3 { color: var(--purple); }
.role-info p { color: var(--text-secondary); font-size: 12px; line-height: 1.5; }
.role-arrow { margin-left: auto; color: var(--text-muted); font-size: 18px; transition: transform 0.15s; }
.role-card:hover .role-arrow { transform: translateX(4px); }

/* ══════════════════════════════════════════
   HEADER
══════════════════════════════════════════ */
.app-header {
  background: rgba(10,15,30,0.95);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(12px);
  position: sticky;
  top: 0;
  z-index: 100;
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  height: 60px;
  display: flex;
  align-items: center;
  gap: 24px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.logo-mark {
  font-size: 22px;
  color: var(--accent);
  line-height: 1;
  filter: drop-shadow(0 0 8px var(--accent));
}
.logo-text {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 18px;
  letter-spacing: -0.5px;
  background: linear-gradient(135deg, #e8edf5, #3b82f6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.role-badge {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  flex-shrink: 0;
}
.role-badge.editor   { background: var(--accent-glow);  color: var(--accent);  border: 1px solid rgba(59,130,246,0.35); }
.role-badge.author   { background: var(--teal-bg);      color: var(--teal);    border: 1px solid rgba(20,184,166,0.35); }
.role-badge.reviewer { background: var(--purple-bg);    color: var(--purple);  border: 1px solid rgba(139,92,246,0.35); }
.main-nav {
  display: flex;
  gap: 4px;
  flex: 1;
}
.nav-btn {
  background: none;
  border: none;
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 13px;
  padding: 6px 14px;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.nav-btn:hover { background: var(--bg-card); color: var(--text-primary); }
.nav-btn.active { background: var(--accent-glow); color: var(--accent); }
.header-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 12px;
}
.user-label {
  font-size: 12px;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 160px;
}
.logout-btn {
  background: none;
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 6px 12px;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.logout-btn:hover { border-color: var(--danger); color: var(--danger); }

/* ══════════════════════════════════════════
   VIEW CONTAINER
══════════════════════════════════════════ */
.view-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 32px 24px;
  width: 100%;
}
.view-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
  gap: 16px;
  flex-wrap: wrap;
}
.view-header h1 {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
}
.view-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

/* ══════════════════════════════════════════
   STATS ROW
══════════════════════════════════════════ */
.stats-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 14px;
  margin-bottom: 28px;
}
.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px 20px;
}
.stat-value {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 5px;
}
.stat-label { color: var(--text-secondary); font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; }
.stat-card.blue    .stat-value { color: var(--accent); }
.stat-card.teal    .stat-value { color: var(--teal); }
.stat-card.warning .stat-value { color: var(--warning); }
.stat-card.success .stat-value { color: var(--success); }
.stat-card.purple  .stat-value { color: var(--purple); }

/* ══════════════════════════════════════════
   ARTICLE GRID & CARDS
══════════════════════════════════════════ */
.article-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
}
.article-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px;
  position: relative;
  transition: all 0.2s;
}
.article-card:hover {
  border-color: var(--border-light);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 10px;
}
.card-title {
  font-weight: 600;
  font-size: 14px;
  line-height: 1.4;
  flex: 1;
}
.card-author { color: var(--text-secondary); font-size: 12px; margin-bottom: 10px; }
.card-meta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 14px;
}
.due-date.overdue { color: var(--danger); font-weight: 600; }
.card-progress { margin-bottom: 14px; }
.progress-bar { height: 4px; background: var(--bg-surface); border-radius: 2px; overflow: hidden; margin-bottom: 4px; }
.progress-fill { height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.4s ease; }
.progress-label { font-size: 11px; color: var(--text-secondary); }
.card-actions { display: flex; gap: 8px; flex-wrap: wrap; }
.card-hint { font-size: 12px; color: var(--text-secondary); margin-bottom: 14px; line-height: 1.5; }

/* ══════════════════════════════════════════
   STATUS BADGES
══════════════════════════════════════════ */
.status-badge {
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}
.status-badge.received       { background: var(--bg-surface); color: var(--text-secondary); border: 1px solid var(--border); }
.status-badge.in-review      { background: var(--warning-bg); color: var(--warning); border: 1px solid rgba(245,158,11,0.3); }
.status-badge.comments-ready { background: var(--success-bg); color: var(--success); border: 1px solid rgba(16,185,129,0.3); }
.status-badge.submitted      { background: var(--success-bg); color: var(--success); border: 1px solid rgba(16,185,129,0.3); }
.status-badge.draft          { background: var(--bg-surface); color: var(--text-muted);      border: 1px solid var(--border); }
.status-badge.pending        { background: var(--warning-bg); color: var(--warning); border: 1px solid rgba(245,158,11,0.3); }
.status-badge.badge-draft    { background: var(--bg-surface); color: var(--text-muted);      border: 1px solid var(--border); }
.status-badge.badge-submitted{ background: var(--success-bg); color: var(--success); border: 1px solid rgba(16,185,129,0.3); }

/* ══════════════════════════════════════════
   BUTTONS
══════════════════════════════════════════ */
.btn-primary, .btn-secondary, .btn-card, .btn-back, .btn-demo, .btn-danger-sm {
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  border-radius: 6px;
  transition: all 0.15s;
  white-space: nowrap;
  border: none;
}
.btn-primary { background: var(--accent); color: #fff; padding: 9px 18px; }
.btn-primary:hover { background: var(--accent-hover); }
.btn-secondary { background: var(--bg-surface); color: var(--text-secondary); padding: 9px 18px; border: 1px solid var(--border); }
.btn-secondary:hover { background: var(--bg-hover); color: var(--text-primary); }
.btn-back { background: none; color: var(--text-muted); padding: 6px 0; font-size: 13px; }
.btn-back:hover { color: var(--text-primary); }
.btn-demo { background: none; color: var(--text-muted); padding: 6px 12px; border: 1px solid var(--border); }
.btn-demo:hover { border-color: var(--accent); color: var(--accent); }
.btn-danger-sm { background: var(--danger-bg); color: var(--danger); padding: 5px 10px; border: 1px solid rgba(239,68,68,0.3); }
.btn-danger-sm:hover { background: var(--danger); color: #fff; }
.btn-card { background: var(--bg-surface); color: var(--text-secondary); padding: 7px 14px; border: 1px solid var(--border); }
.btn-card:hover { background: var(--bg-hover); color: var(--text-primary); }
.btn-card.primary { background: var(--accent-glow); color: var(--accent); border-color: rgba(59,130,246,0.3); }
.btn-card.primary:hover { background: var(--accent); color: #fff; }
.btn-card.teal { background: var(--teal-bg); color: var(--teal); border-color: rgba(20,184,166,0.3); }
.btn-card.teal:hover { background: var(--teal); color: #fff; }
.btn-card.purple { background: var(--purple-bg); color: var(--purple); border-color: rgba(139,92,246,0.3); }
.btn-card.purple:hover { background: var(--purple); color: #fff; }

/* ══════════════════════════════════════════
   FORMS
══════════════════════════════════════════ */
.form-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px;
  margin-bottom: 24px;
}
.form-card.compact { padding: 20px; }
.form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
.form-group:last-child { margin-bottom: 0; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
label { font-size: 12px; color: var(--text-secondary); letter-spacing: 0.03em; }
.req { color: var(--danger); }
input[type="text"],
input[type="email"],
input[type="date"],
textarea,
select {
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 13px;
  padding: 10px 14px;
  width: 100%;
  transition: border-color 0.15s;
  outline: none;
}
input:focus, textarea:focus, select:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
textarea { resize: vertical; min-height: 100px; }
.field-hint { font-size: 11px; color: var(--text-muted); margin-top: 4px; }
.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 24px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}
.filter-select {
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 6px 12px;
  border-radius: 6px;
  cursor: pointer;
}

/* ══════════════════════════════════════════
   REVIEWER CHECKBOXES
══════════════════════════════════════════ */
.reviewer-grid { display: grid; gap: 10px; }
.reviewer-check-card {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 13px 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.15s;
}
.reviewer-check-card:hover { border-color: var(--border-light); background: var(--bg-hover); }
.reviewer-check-card input[type="checkbox"] { width: 16px; height: 16px; flex-shrink: 0; accent-color: var(--accent); }
.reviewer-name { font-size: 13px; font-weight: 500; }
.reviewer-specialty { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

/* ══════════════════════════════════════════
   RECOMMENDATION OPTIONS
══════════════════════════════════════════ */
.recommendation-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 10px;
}
.radio-card { cursor: pointer; }
.radio-card input { display: none; }
.radio-label {
  display: block;
  padding: 12px 14px;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  transition: all 0.15s;
}
.radio-label:hover { background: var(--bg-hover); }
.radio-card input:checked + .radio-label { border-width: 2px; }
.radio-label.accept { color: var(--success); }
.radio-card input:checked + .radio-label.accept { background: var(--success-bg); border-color: var(--success); }
.radio-label.minor { color: var(--accent); }
.radio-card input:checked + .radio-label.minor { background: var(--accent-glow); border-color: var(--accent); }
.radio-label.major { color: var(--warning); }
.radio-card input:checked + .radio-label.major { background: var(--warning-bg); border-color: var(--warning); }
.radio-label.reject { color: var(--danger); }
.radio-card input:checked + .radio-label.reject { background: var(--danger-bg); border-color: var(--danger); }

/* ══════════════════════════════════════════
   ARTICLE SUMMARY CARD
══════════════════════════════════════════ */
.article-summary-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 20px;
  margin-bottom: 20px;
}
.article-summary-card h3 { font-size: 15px; margin-bottom: 6px; }
.article-summary-card .meta { font-size: 12px; color: var(--text-muted); }

/* ══════════════════════════════════════════
   EMPTY / LOADING STATES
══════════════════════════════════════════ */
.empty-state {
  text-align: center;
  padding: 64px 24px;
  color: var(--text-muted);
  grid-column: 1 / -1;
}
.empty-icon { font-size: 48px; margin-bottom: 16px; }
.loading-state { text-align: center; padding: 40px; color: var(--text-muted); grid-column: 1/-1; }

/* ══════════════════════════════════════════
   REVIEW CARDS
══════════════════════════════════════════ */
.review-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  margin-bottom: 16px;
}
.review-card h4 { margin-bottom: 16px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.review-section { margin-bottom: 16px; }
.review-section h5 {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-bottom: 6px;
}
.review-section p { color: var(--text-secondary); font-size: 13px; line-height: 1.6; }
.reviews-list { margin-top: 24px; }

/* ══════════════════════════════════════════
   REVIEWER LIST
══════════════════════════════════════════ */
.reviewers-list-container { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
.reviewer-list-item {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 13px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.reviewer-list-name { font-weight: 500; font-size: 13px; }
.reviewer-list-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

/* ══════════════════════════════════════════
   AUTHOR DETAIL
══════════════════════════════════════════ */
.author-detail {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  margin-bottom: 24px;
}
.author-detail h2 { font-size: 20px; margin-bottom: 12px; }

/* ══════════════════════════════════════════
   TIMELINE
══════════════════════════════════════════ */
.timeline { display: flex; flex-direction: column; gap: 0; margin-top: 20px; }
.timeline-item {
  display: flex;
  gap: 16px;
  padding-bottom: 20px;
  position: relative;
}
.timeline-item:not(:last-child)::before {
  content: '';
  position: absolute;
  left: 18px;
  top: 38px;
  bottom: 0;
  width: 2px;
  background: var(--border);
}
.timeline-dot {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
  border: 2px solid var(--border);
  background: var(--bg-card);
}
.timeline-dot.done { background: var(--success-bg); border-color: var(--success); color: var(--success); }
.timeline-dot.active { background: var(--accent-glow); border-color: var(--accent); color: var(--accent); }
.timeline-content { flex: 1; padding-top: 6px; }
.timeline-title { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
.timeline-desc { font-size: 12px; color: var(--text-muted); }

/* ══════════════════════════════════════════
   REVIEWER ASSIGNMENT CHIPS
══════════════════════════════════════════ */
.assignment-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: 10px; }
.reviewer-chip {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 11px;
  color: var(--text-secondary);
}
.reviewer-chip .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted); }
.reviewer-chip .dot.submitted { background: var(--success); }
.reviewer-chip .dot.pending   { background: var(--warning); }

/* ══════════════════════════════════════════
   SECTION TITLE
══════════════════════════════════════════ */
.section-title {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}

/* ══════════════════════════════════════════
   MY REVIEW CARDS (Reviewer)
══════════════════════════════════════════ */
.my-reviews-grid { display: grid; gap: 14px; }
.my-review-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px;
  transition: all 0.2s;
}
.my-review-card:hover { border-color: var(--border-light); transform: translateY(-1px); }
.my-review-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
.my-review-title { font-weight: 600; font-size: 14px; flex: 1; line-height: 1.4; }
.due-info { font-size: 12px; margin: 8px 0 14px; }
.due-info.overdue { color: var(--danger); font-weight: 600; }
.due-info.urgent  { color: var(--warning); }
.due-info.ok      { color: var(--text-muted); }

/* ══════════════════════════════════════════
   INFO BOX
══════════════════════════════════════════ */
.info-box {
  background: var(--accent-glow);
  border: 1px solid rgba(59,130,246,0.3);
  border-radius: var(--radius);
  padding: 13px 18px;
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}

/* ══════════════════════════════════════════
   OFFLINE BAR
══════════════════════════════════════════ */
.offline-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(245,158,11,0.15);
  border-top: 1px solid rgba(245,158,11,0.3);
  color: var(--warning);
  text-align: center;
  padding: 8px;
  font-size: 12px;
  z-index: 50;
}
.offline-bar.hidden { display: none; }

/* ══════════════════════════════════════════
   TOAST
══════════════════════════════════════════ */
.toast-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.toast {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 16px;
  font-size: 13px;
  min-width: 260px;
  max-width: 360px;
  animation: slideIn 0.3s ease;
  box-shadow: var(--shadow);
}
.toast.success { border-color: rgba(16,185,129,0.5); }
.toast.success span:first-child { color: var(--success); }
.toast.error   { border-color: rgba(239,68,68,0.5); }
.toast.error   span:first-child { color: var(--danger); }
.toast.info    { border-color: rgba(59,130,246,0.5); }
.toast.info    span:first-child { color: var(--accent); }
.toast.warning { border-color: rgba(245,158,11,0.5); }
.toast.warning span:first-child { color: var(--warning); }

@keyframes slideIn  { from { opacity:0; transform:translateX(20px); } to { opacity:1; transform:translateX(0); } }
@keyframes fadeOut  { to   { opacity:0; transform:translateX(20px); } }

/* ══════════════════════════════════════════
   PENDING SYNC INDICATOR
══════════════════════════════════════════ */
.pending-sync-indicator {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--warning);
  box-shadow: 0 0 8px var(--warning);
}

/* ══════════════════════════════════════════
   OFFLINE SAVE HINT
══════════════════════════════════════════ */
.offline-save-hint { font-size: 11px; color: var(--text-muted); }

/* ══════════════════════════════════════════
   SYNC BADGE
══════════════════════════════════════════ */
.sync-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 11px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: border-color 0.15s;
}
.sync-badge:hover { border-color: var(--border-light); }
.sync-dot { width: 7px; height: 7px; border-radius: 50%; }
.sync-dot.online  { background: var(--success); box-shadow: 0 0 6px var(--success); }
.sync-dot.offline { background: var(--text-muted); }
.sync-dot.pending { background: var(--warning); box-shadow: 0 0 6px var(--warning); }
.sync-label { font-size: 11px; color: var(--text-secondary); }

/* ══════════════════════════════════════════
   SYNC BTN
══════════════════════════════════════════ */
.sync-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  background: none;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 12px;
  cursor: pointer;
  transition: all 0.15s;
}
.sync-btn:hover { border-color: var(--accent); color: var(--accent); }
.sync-btn.spinning svg { animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ══════════════════════════════════════════
   SYNC PANEL
══════════════════════════════════════════ */
.sync-panel {
  position: fixed;
  top: 70px;
  right: 24px;
  width: 320px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  z-index: 200;
}
.sync-panel.hidden { display: none; }
.sync-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
}
.sync-panel-header h3 { font-size: 14px; }
.sync-panel-header button {
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 18px;
  padding: 0 4px;
}
.sync-queue-list { padding: 12px; max-height: 200px; overflow-y: auto; }
.sync-queue-item {
  display: flex;
  justify-content: space-between;
  padding: 8px 10px;
  border-radius: 6px;
  font-size: 12px;
  color: var(--text-secondary);
}
.sync-queue-item:hover { background: var(--bg-hover); }
.op-type { color: var(--accent); font-weight: 500; }
.empty-sync { text-align: center; color: var(--text-muted); padding: 16px; font-size: 12px; }
.sync-panel-actions { padding: 12px 14px; border-top: 1px solid var(--border); }

/* ══════════════════════════════════════════
   HEADER BADGES
══════════════════════════════════════════ */
.header-badges { display: flex; align-items: center; gap: 10px; }
.badge { padding: 3px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
.badge-draft     { background: var(--bg-surface); color: var(--text-muted); border: 1px solid var(--border); }
.badge-submitted { background: var(--success-bg); color: var(--success); border: 1px solid rgba(16,185,129,0.3); }

/* ══════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════ */
@media (max-width: 768px) {
  .form-row { grid-template-columns: 1fr; }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .article-grid { grid-template-columns: 1fr; }
  .recommendation-options { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .header-inner { padding: 0 16px; gap: 10px; }
  .main-nav { display: none; }
  .user-label { display: none; }
  .view-container { padding: 20px 16px; }
  .view-header h1 { font-size: 22px; }
}

/* ── PDF STYLES ─────────────────────────────────────────────── */
.pdf-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  background: rgba(99, 179, 237, 0.15);
  color: #63b3ed;
  border: 1px solid rgba(99, 179, 237, 0.3);
}
.pdf-missing {
  font-size: 11px;
  color: var(--text-muted);
  font-style: italic;
}
.pdf-section { margin-top: 20px; }
.current-pdf {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: rgba(99, 179, 237, 0.08);
  border: 1px solid rgba(99, 179, 237, 0.2);
  border-radius: 8px;
  margin-bottom: 12px;
}
.pdf-info { flex: 1; }
.pdf-info strong { display: block; font-size: 13px; color: var(--text-primary); }
.pdf-info span   { font-size: 11px; color: var(--text-muted); }
.pdf-icon { font-size: 20px; }

.pdf-upload-area {
  border: 2px dashed rgba(255,255,255,0.12);
  border-radius: 10px;
  padding: 24px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: rgba(255,255,255,0.02);
}
.pdf-upload-area.drag-over {
  border-color: var(--accent);
  background: rgba(159, 122, 234, 0.08);
}
.pdf-drop-icon { font-size: 28px; margin-bottom: 8px; }
.pdf-drop-content p { font-size: 13px; color: var(--text-secondary); margin: 6px 0; }
.pdf-selected {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px;
  background: rgba(72, 187, 120, 0.1);
  border-radius: 8px;
  font-size: 13px;
  color: var(--text-primary);
}

/* ── COMMENT STYLES ─────────────────────────────────────────── */
.comment-section {
  border-top: 1px solid rgba(255,255,255,0.06);
  margin-top: 20px;
  padding-top: 16px;
}
.comment-section h5 {
  font-size: 12px;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 12px;
}
.comment-thread {
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-height: 320px;
  overflow-y: auto;
  padding-right: 4px;
}
.comment-item {
  padding: 10px 14px;
  border-radius: 8px;
  border-left: 3px solid transparent;
}
.comment-item.editor   { background: rgba(159, 122, 234, 0.08); border-color: #9f7aea; }
.comment-item.reviewer { background: rgba(66, 153, 225, 0.08);  border-color: #4299e1; }
.comment-item.author   { background: rgba(72, 187, 120, 0.08);  border-color: #48bb78; }

.comment-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  flex-wrap: wrap;
}
.comment-author { font-size: 12px; font-weight: 700; color: var(--text-primary); }
.comment-role   { font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 10px; text-transform: uppercase; }
.role-editor    { background: rgba(159,122,234,0.2); color: #b794f4; }
.role-reviewer  { background: rgba(66,153,225,0.2);  color: #63b3ed; }
.role-author    { background: rgba(72,187,120,0.2);  color: #68d391; }
.comment-date   { font-size: 10px; color: var(--text-muted); margin-left: auto; }
.comment-content { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }

.comment-compose { margin-top: 14px; display: flex; flex-direction: column; gap: 8px; }
.comment-input {
  width: 100%;
  padding: 10px 12px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  color: var(--text-primary);
  font-size: 13px;
  font-family: inherit;
  resize: vertical;
  transition: border-color 0.2s;
  box-sizing: border-box;
}
.comment-input:focus { outline: none; border-color: var(--accent); }
.no-comments { font-size: 12px; color: var(--text-muted); text-align: center; padding: 12px; font-style: italic; }
.warning-box { background: rgba(246, 173, 85, 0.1); border: 1px solid rgba(246, 173, 85, 0.3); border-radius: 8px; padding: 12px 16px; font-size: 13px; color: var(--warning); display: flex; align-items: center; gap: 10px; }

/* ── REVIEWER SWITCHER (beta) ─────────────────────────────── */
#reviewerSwitcher {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  background: rgba(159, 122, 234, 0.08);
  border-bottom: 1px solid rgba(159, 122, 234, 0.2);
}
#reviewerSwitcher select {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(159, 122, 234, 0.35);
  border-radius: 6px;
  color: var(--text-primary);
  font-size: 12px;
  padding: 4px 8px;
  cursor: pointer;
  outline: none;
}
#reviewerSwitcher select:focus {
  border-color: #9f7aea;
}
.beta-tag {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #9f7aea;
  background: rgba(159, 122, 234, 0.15);
  border: 1px solid rgba(159, 122, 234, 0.3);
  border-radius: 4px;
  padding: 1px 5px;
}

/* ── ACCESSIBILITY FIXES ──────────────────────────────────── */
/* role-card is now a <button>, reset button defaults */
button.role-card {
  width: 100%;
  text-align: left;
  font-family: inherit;
  cursor: pointer;
}
/* Ensure sufficient focus ring on all interactive elements */
:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
/* Fix low-contrast helper text */
.field-hint   { color: var(--text-secondary) !important; }
.pdf-missing  { color: var(--text-secondary) !important; }
.no-comments  { color: var(--text-secondary) !important; }
.card-meta    { color: var(--text-secondary); }

/* ── REVIEWER SWITCHER (inline en dashboard) ─────────────────── */
.reviewer-switcher-panel {
  background: rgba(139, 92, 246, 0.07);
  border: 1px solid rgba(139, 92, 246, 0.25);
  border-radius: var(--radius);
  padding: 12px 18px;
  margin-bottom: 24px;
}
.reviewer-switcher-inner {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.switcher-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  white-space: nowrap;
}
.reviewer-selector-select {
  flex: 1;
  min-width: 200px;
  background: var(--bg-surface);
  border: 1px solid rgba(139, 92, 246, 0.4);
  border-radius: 8px;
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 13px;
  padding: 8px 12px;
  cursor: pointer;
  outline: none;
  transition: border-color 0.15s;
}
.reviewer-selector-select:focus {
  border-color: var(--purple);
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.15);
}
.beta-pill {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--purple);
  background: rgba(139, 92, 246, 0.12);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 20px;
  padding: 2px 8px;
  white-space: nowrap;
}
